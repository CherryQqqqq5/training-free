.venv/
__pycache__/
*.pyc
.DS_Store

# Local secrets (templates like .env.example stay tracked)
.env
.env.local
.env.*.local

# Python tooling / packaging
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Notebooks
.ipynb_checkpoints/

# Experiment & ML run artifacts (large; keep on disk, not in git)
wandb/
mlruns/
lightning_logs/
/checkpoints/
/runs/

# IDE / OS
.idea/
Thumbs.db

# Tracked output tree: keep compact reports only.
/outputs/*
!/outputs/README.md
!/outputs/artifacts/
!/outputs/artifacts/**
!/outputs/artifacts/**/*.md
!/outputs/artifacts/**/*.json

# Never commit raw benchmark traces or BFCL lock files; compact summaries belong under outputs/artifacts/.
outputs/**/traces/*.json
outputs/**/bfcl/.file_locks/**
outputs/**/bfcl/result/**
outputs/**/bfcl/score/**
